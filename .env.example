# Compliance-as-Code Platform - Environment Variables
# Copy this file to .env.local and fill in the values
# Full SSO credential sourcing guide: docs/SSO_SETUP.md

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# ── Clerk (Dashboard Access Control) ──
# Used for /workflow-canvas and /firewall-review access gates.
# Store user role in Clerk public metadata: role=admin|architect|arb_reviewer|project_team
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── SSO Authentication ──
# The platform supports TWO SSO modes. Configure ONE of them.
# When neither is configured, a dev credentials provider is used.
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Option A: Keycloak Identity Broker  [RECOMMENDED]
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#   Keycloak provides fully OIDC-compliant auth and federates to
#   ADFS via SAML 2.0. No changes to existing ADFS config needed.
#   Architecture: App ──OIDC──→ Keycloak ──SAML 2.0──→ ADFS ──→ AD
#
#   Setup:
#   1. Deploy Keycloak (Docker / standalone)
#   2. Create realm "hkma", add SAML Identity Provider pointing to ADFS
#   3. Create client "compliance-platform" (confidential, OIDC)
#   4. Redirect URI: https://your-domain/api/auth/callback/keycloak
#   5. Map ADFS groups to Keycloak roles or group claims
#
KEYCLOAK_ISSUER=https://keycloak.hkma.gov.hk/realms/hkma
KEYCLOAK_CLIENT_ID=compliance-platform
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Option B: Direct ADFS  (manual endpoints — no OIDC discovery)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#   HKMA ADFS (maadfsd.hkma.gov.hk) is NOT fully OIDC-compliant:
#   - /.well-known/openid-configuration returns 404
#   - Access token issuer ≠ ID token issuer (two different values)
#   Manual endpoint URLs are required.
#
#   Setup in ADFS Management:
#   1. Add Application Group → Server Application → generate Client ID/Secret
#   2. Redirect URI: https://your-domain/api/auth/callback/adfs
#   3. Add Issuance Transform Rules to emit claims:
#      - Name ID (= UPN)
#      - E-Mail Address
#      - Display Name
#      - Group Membership ("groups" claim with AD group sAMAccountName)
#
#   Network: User → WAP (DMZ :443) → Firewall → ADFS (Intranet :443) → AD
#   Ports: HTTPS 443 (auth), HTTP 80 (CRL), TCP 49443 (cert auth, optional)
#
# ADFS_ISSUER=https://maadfsd.hkma.gov.hk/adfs
# ADFS_CLIENT_ID=your-client-id-from-adfs
# ADFS_CLIENT_SECRET=your-client-secret-from-adfs
# ADFS_AUTHORIZATION_URL=https://maadfsd.hkma.gov.hk/adfs/oauth2/authorize
# ADFS_TOKEN_URL=https://maadfsd.hkma.gov.hk/adfs/oauth2/token

# ── GitLab ──
GITLAB_URL=https://gitlab.internal.hkma.org
GITLAB_API_TOKEN=your-gitlab-api-token
GITLAB_IDAC_GROUP=idac

# ── JIRA ──
JIRA_BASE_URL=https://jira.internal.hkma.org
JIRA_SERVICE_ACCOUNT_TOKEN=your-jira-pat
JIRA_WEBHOOK_SECRET=your-webhook-secret
JIRA_FIREWALL_PROJECT_KEY=ITISUFR

# ── LLM (Phase 2) ──
LLM_PROVIDER=maas
LLM_API_KEY=your-llm-api-key
LLM_ENDPOINT=https://maas.internal.hkma.org/v1
LLM_MODEL=gpt-4

# ── App ──
LOG_LEVEL=info
NODE_TLS_REJECT_UNAUTHORIZED=1
